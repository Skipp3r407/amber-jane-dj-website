# Resend (https://resend.com) — required for contact form emails
RESEND_API_KEY=re_xxxxxxxx

# Verified sender (used by API if set). Also accepts RESEND_FROM for backwards compatibility.
EMAIL_FROM="Amber Jane <onboarding@resend.dev>"
# RESEND_FROM="Amber Jane <onboarding@resend.dev>"

# Where booking inquiries are delivered
PROJECT_INQUIRY_TO_EMAIL=you@yourdomain.com
# CONTACT_TO_EMAIL=you@yourdomain.com

# Optional: public URL to an MP3 for the first mix card demo player
# NEXT_PUBLIC_MIX_DEMO_URL=https://yourcdn.com/demo.mp3
